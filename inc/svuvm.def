; svuvm.def - Module definition file for Windows _svuvm.pyd
;
; This .def file controls which symbols are exported from _svuvm.pyd.
;
; EXPORTS section lists symbols that must be visible to:
;   - Python (PyInit__svuvm)
;   - SystemVerilog simulator (DPI export functions called from SV)
;
; The dpi_stub.c stubs that satisfy VPI references (e.g. vpi_register_cb,
; vpi_get, etc.) are compiled directly into _svuvm.pyd and are NOT
; exported here, because they are private implementation details.
; At runtime, when the simulator loads _svuvm.pyd, the simulator's
; own VPI symbols override these stubs (Windows DLL symbol resolution
; prefers the loading module's symbols over the loaded module's stubs).

LIBRARY _svuvm
EXPORTS
    ; Python extension module init (provided by nanobind)
    PyInit__svuvm

    ; ===== UVM DPI exports (called by SystemVerilog) =====
    process_pool_run
    process_pool_clear
    print_factory
    set_factory_inst_override
    set_factory_type_override
    create_object_by_name
    create_component_by_name
    debug_factory_create
    find_factory_override
    print_topology
    set_timeout
    set_finish_on_completion
    set_drain_time
    get_drain_time
    get_objection_count
    get_objection_total
    display_objections
    get_current_phase_name
    get_phase_state
    get_phase_state_name
    phase_jump
    uvm_objection_op
    component_get_num_children
    component_get_child_name
    component_get_parent
    component_get_type_name
    component_sprint
    uvm_top_sprint
    is_type_registered
    dbg_print
    tlm_connect
    wait_on
    wait_off
    wait_trigger
    wait_ptrigger
    get_trigger_time
